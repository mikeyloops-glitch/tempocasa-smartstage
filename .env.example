# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# OpenAI image editing
OPENAI_API_KEY=sk-proj-replace_me
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_TOUR_MODEL=gpt-4o-mini
OPENAI_GEOMETRY_MODEL=gpt-4o-mini
# Set to false only if you want to skip the irregular-wall/architecture preflight.
OPENAI_GEOMETRY_ANALYSIS=true
# Use medium for faster Vercel demos. Use high for final-quality production renders.
OPENAI_IMAGE_QUALITY=medium

# 3D virtual-tour reconstruction pipeline
# Leave blank for demo mode. When you provide the API pipeline, set the endpoint
# that accepts multipart FormData: manifest, mediaIndex, and media files.
TOUR_RECONSTRUCTION_API_URL=
TOUR_RECONSTRUCTION_API_KEY=
TOUR_RECONSTRUCTION_AUTH_HEADER=Authorization
# Optional polling URL, for example: https://api.example.com/jobs/{jobId}
TOUR_RECONSTRUCTION_STATUS_URL=
TOUR_RECONSTRUCTION_OUTPUT_FORMAT=sog

# Cloudinary
CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me
CLOUDINARY_UPLOAD_FOLDER=tempocasa-smartstage

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
